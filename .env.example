# Cambridge TCG — Environment Variables
# Copy to .env and fill in production values
# Usage: source .env (for stock CLI) or set in Lambda config (for pricing pipeline)

# ── Database (RDS via Proxy) ─────────────────────────────────────
# Used by: ALL pricing Lambdas + stock CLI (--pull-prices)
PROXY_ENDPOINT=your-rds-proxy-endpoint.rds.amazonaws.com
DB_USER=your-db-username
DB_PASSWORD=your-db-password
DATABASE_NAME=op_cardrush_link
DB_PORT=5432
TABLE_NAME=cardrush_link

# ── FX Rate API ──────────────────────────────────────────────────
# Used by: cardrush-fx-updater Lambda
AMDOREN_API_KEY=your-amdoren-api-key

# ── Shopify ──────────────────────────────────────────────────────
# Used by: api-shopify Lambda, stock sync/push
SHOPIFY_STORE=your-store.myshopify.com
SHOPIFY_CLIENT_ID=your-app-client-id
SHOPIFY_CLIENT_SECRET=shpss_xxxxxxxxxxxxxxxxxxxx
SHOPIFY_API_VERSION=2024-10
# Legacy (pricing Lambda only — will migrate to client credentials)
# SHOPIFY_API_PASSWORD=shpat_xxxxxxxxxxxxxxxxxxxx

# ── Shopify Webhooks ──────────────────────────────────────────────
# Used by: shopify-order-webhook Lambda
SHOPIFY_WEBHOOK_SECRET=your-webhook-signing-secret

# ── eBay ─────────────────────────────────────────────────────────
# Used by: api-ebay Lambda (credentials stored in AWS Secrets Manager)
EBAY_SECRET_NAME=ebay-trading-api-credentials
EBAY_SITE_ID=3

# ── eBay Browse Monitor ────────────────────────────────────────
# Used by: browse-monitor Lambda
EBAY_OUR_SELLER_ID=cambridge_tcg
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:034362054546:cambridge-tcg-pipeline-alerts
# ACQUISITION_THRESHOLD=0.50
# UNDERPRICED_THRESHOLD=0.70
# MIN_PRICE_RATIO=0.30

# ── S3 Buckets ───────────────────────────────────────────────────
# Used by: scraper-cardrush Lambda
SOURCE_BUCKET=pricedata-tcg
SOURCE_KEY=daily_prices.xlsx

# Used by: stock CLI (SKU resolver) — defaults work unless bucket changed
# S3_BUCKET=pricedata-tcg
# S3_KEY=daily_prices.xlsx

# ── Landed Cost Rates ──────────────────────────────────────────────
# Used by: price-calculator Lambda
# landed_cost_gbp = cost_gbp * (1 + SHIPPING_RATE/100) + SHIPPING_FLAT_GBP
# SHIPPING_RATE=5
# SHIPPING_FLAT_GBP=1.00

# ── Stock Inventory Admin ────────────────────────────────────────
# Used by: stock/inventory/app.py (Streamlit frontend via boto3 invoke)
# Defaults work if AWS credentials are configured and Lambda is deployed
# STOCK_LAMBDA_NAME=stock-inventory-api

# ── Trade-In Admin ───────────────────────────────────────────────
# Used by: price-history-api Lambda
# ADMIN_SECRET: Required for admin status update endpoint. Generate with: openssl rand -hex 32
ADMIN_SECRET=your-admin-secret-here

# ── Email (SES) ─────────────────────────────────────────────────
# Used by: price-history-api Lambda (trade-in confirmation + status emails)
SES_ENABLED=false
SES_SANDBOX_MODE=true

# ── Pricing Parameters ───────────────────────────────────────────
# Used by: price-calculator Lambda (defaults shown, override if needed)
# VAT_RATE=20
# EBAY_BUSINESS_FEE=12
# CARDMARKET_FEE=8
# SHOPIFY_FEE=5

# ── Dynamic Margin (velocity-based) ─────────────────────────────
# Used by: price-calculator Lambda
# Margin scales with sales velocity: slow sellers → lower margin, fast sellers → higher
# To revert to flat margin: set all three to the same value (e.g. 18)
# MARGIN_MIN=12              # Floor margin % for slow sellers (<=VELOCITY_LOW units)
# MARGIN_MAX=22              # Ceiling margin % for fast sellers (>=VELOCITY_HIGH units)
# MARGIN_DEFAULT=18          # Margin % for SKUs with zero sales data
# VELOCITY_WINDOW_DAYS=30    # Look-back window for counting sales
# VELOCITY_LOW=1             # Units sold threshold for minimum margin
# VELOCITY_HIGH=8            # Units sold threshold for maximum margin
